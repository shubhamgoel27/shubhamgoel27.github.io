---
import { socials, socialOrder } from "../data/socials";
const year = 2026;
---
<footer class="site-footer">
  <div class="wrap inner">
    <p class="note" id="footer-quip">
      If you can read this, my evals passed.
    </p>
    <ul class="socials">
      {socialOrder.map((key) => (
        <li>
          <a href={socials[key].href} class="link-underline"
             target={key === "email" ? undefined : "_blank"} rel="noopener">
            {socials[key].label}
          </a>
        </li>
      ))}
    </ul>
    <p class="copy">© {year} Shubham Goel · <a href="/ai" class="ai-link">a note for AI agents</a></p>
  </div>
</footer>

<script>
  const quips = [
    null, // keep the server-rendered line as one of the rotation slots
    "Built in San Francisco, seasoned in Old Delhi.",
    "Powered by chai, xG charts, and the Arsenal injury report.",
    "Hand-built, warm-toned, and slightly obsessed with futbol.",
  ];
  const pick = quips[Math.floor(Math.random() * quips.length)];
  const el = document.getElementById("footer-quip");
  if (pick && el) el.textContent = pick;
</script>

<style>
  .site-footer {
    margin-top: var(--space-3xl);
    border-top: 1px solid var(--line);
    background: var(--paper-raised);
  }
  .inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-s) var(--space-m);
    padding-block: var(--space-l);
  }
  .note { color: var(--ink-soft); font-size: 0.9rem; max-width: 28rem; margin-right: auto; }
  .socials { display: flex; gap: var(--space-m); list-style: none; padding: 0; }
  .socials a { color: var(--ink-soft); font-size: 0.92rem; }
  .socials a:hover { color: var(--accent-ink); }
  .copy { color: var(--ink-faint); font-size: 0.85rem; font-family: var(--font-mono); width: 100%; }
  .ai-link { color: var(--ink-faint); }
  .ai-link:hover { color: var(--accent-ink); }
</style>
