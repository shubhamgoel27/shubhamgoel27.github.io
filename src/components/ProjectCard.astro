---
import { Image } from "astro:assets";
import type { Project } from "../data/projects";
interface Props { project: Project; }
const { project } = Astro.props;
const primary = project.links[0];
---
<article class="card">
  {project.image && (
    <div class="shot">
      <Image src={project.image} alt={`${project.name} screenshot`} width={720} loading="lazy" />
    </div>
  )}
  <div class="head">
    <h3 class="name">
      {primary
        ? <a href={primary.href} class="link-underline" target="_blank" rel="noopener">{project.name}</a>
        : project.name}
    </h3>
    {project.links.length === 0 && <span class="soon">repo coming soon</span>}
  </div>

  <p class="tagline">{project.tagline}</p>

  <p class="result">
    <span class="dot" aria-hidden="true"></span>
    {project.resultHref
      ? <a href={project.resultHref} class="result-link" target="_blank" rel="noopener">{project.result} ↗</a>
      : project.result}
  </p>

  <div class="foot">
    <ul class="tags">
      {project.tags.map((t) => <li class="tag">{t}</li>)}
    </ul>
    {project.links.length > 0 && (
      <ul class="links">
        {project.links.map((l) => (
          <li><a href={l.href} class="link-underline" target="_blank" rel="noopener">{l.label} ↗</a></li>
        ))}
      </ul>
    )}
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-m);
    background: var(--paper-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-m);
    box-shadow: var(--shadow-sm);
    height: 100%;
    transition: transform var(--t-norm), box-shadow var(--t-norm), border-color var(--t-norm);
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--line-strong);
  }
  .shot {
    margin: calc(-1 * var(--space-m)) calc(-1 * var(--space-m)) var(--space-2xs);
    border-bottom: 1px solid var(--line);
    border-radius: var(--radius-m) var(--radius-m) 0 0;
    overflow: hidden;
    background: var(--paper-sunk);
  }
  .shot :global(img) {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
    transition: transform var(--t-norm);
  }
  .card:hover .shot :global(img) { transform: scale(1.03); }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-s); }
  .name { font-size: var(--step-1); }
  .name a { color: var(--ink); }
  .name a:hover { color: var(--accent-ink); }
  .soon {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.03em;
    color: var(--accent-ink);
    background: var(--accent-wash);
    padding: 0.15em 0.55em;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }
  .tagline { color: var(--ink-soft); font-size: 0.96rem; line-height: 1.55; }
  .result {
    display: flex;
    align-items: baseline;
    gap: 0.55em;
    font-size: 0.92rem;
    color: var(--ink);
    font-weight: 500;
    margin-top: auto;
    padding-top: var(--space-2xs);
  }
  .dot { flex: none; width: 7px; height: 7px; border-radius: 50%; background: var(--accent); transform: translateY(-1px); }
  .result-link {
    color: var(--accent-ink);
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 100% 1px;
    transition: background-size var(--t-norm);
  }
  .result-link:hover { background-size: 100% 2px; }
  .foot { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--space-s); padding-top: var(--space-xs); }
  .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; list-style: none; padding: 0; }
  .links { display: flex; gap: var(--space-s); list-style: none; padding: 0; }
  .links a { font-size: 0.85rem; font-weight: 500; color: var(--accent-ink); }
</style>
