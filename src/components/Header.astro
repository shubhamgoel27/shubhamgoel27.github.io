---
import ThemeToggle from "./ThemeToggle.astro";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const nav = [
  { label: "Building", href: "/building" },
  { label: "Writing", href: "/blog" },
  { label: "About", href: "/about" },
  { label: "Now", href: "/now" },
];
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header class="site-header">
  <div class="wrap bar">
    <a href="/" class="brand" aria-label="Home">
      <span class="monogram">SG</span>
      <span class="brand-name">Shubham Goel</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href} class:list={["nav-link", "link-underline", { active: isActive(item.href) }]}
               aria-current={isActive(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in srgb, var(--paper) 82%, transparent);
    backdrop-filter: saturate(1.4) blur(10px);
    border-bottom: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
  }
  .bar {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    min-height: 4rem;
    padding-block: var(--space-2xs);
  }
  .brand { display: inline-flex; align-items: center; gap: 0.6rem; color: var(--ink); margin-right: auto; }
  .monogram {
    display: grid; place-items: center;
    width: 2.1rem; height: 2.1rem;
    font-family: var(--font-serif); font-weight: 600; font-size: 0.95rem;
    color: var(--paper-raised); background: var(--accent);
    border-radius: var(--radius-s);
    box-shadow: var(--shadow-sm);
    transition: transform var(--t-norm);
  }
  .brand:hover .monogram { transform: rotate(-6deg); }
  .brand-name { font-family: var(--font-serif); font-weight: 560; font-size: 1.05rem; letter-spacing: -0.01em; }
  nav ul { display: flex; align-items: center; gap: clamp(0.9rem, 2.5vw, 1.6rem); list-style: none; padding: 0; }
  .nav-link { color: var(--ink-soft); font-size: 0.96rem; font-weight: 500; }
  .nav-link:hover { color: var(--ink); }
  .nav-link.active { color: var(--accent-ink); background-size: 100% 1.5px; }

  @media (max-width: 34rem) {
    .brand-name { display: none; }
    .bar { gap: var(--space-s); }
    nav ul { gap: 0.9rem; }
    .nav-link { font-size: 0.9rem; }
  }
</style>
