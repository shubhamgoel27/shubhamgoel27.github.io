---
// Hand-drawn underline squiggle. Animates its draw on load.
interface Props { width?: string; }
const { width = "min(15rem, 60%)" } = Astro.props;
---
<svg class="squiggle" viewBox="0 0 300 14" fill="none" preserveAspectRatio="none" aria-hidden="true" style={`width:${width}`}>
  <path d="M2 9C40 3 70 11 110 7C150 3 180 12 220 7C255 3 280 9 298 5"
        stroke="var(--accent)" stroke-width="3.5" stroke-linecap="round"/>
</svg>

<style>
  .squiggle {
    height: 0.7rem;
    margin-top: 0.4rem;
    overflow: visible;
  }
  .squiggle path {
    stroke-dasharray: 320;
    stroke-dashoffset: 320;
    animation: draw 1.1s var(--ease) 0.25s forwards;
  }
  @keyframes draw { to { stroke-dashoffset: 0; } }
  @media (prefers-reduced-motion: reduce) {
    .squiggle path { animation: none; stroke-dashoffset: 0; }
  }
</style>
