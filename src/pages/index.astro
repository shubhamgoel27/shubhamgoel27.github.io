---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import CardBlog from "../components/CardBlog.astro";
import { getCollection } from "astro:content";
import Card from "../components/Card.astro";
import Icon from "../components/Icon.astro";
import socials from "../data/socials";
const blogPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
import { cardBlogBackgroundColors } from "../data/colors";
---

<BaseLayout
	title="Shubham Goel"
	description="ML Engineer building with multimodal LLMs and AI agents."
>
	<section class="intro-section-container padding-top-l padding-bottom-l">
		<div class="intro-container">
			<div class="intro margin-bottom-s">
				<h1>Hi, I'm<br />Shubham Goel.</h1>
			</div>
			<p>ML Engineer, building with multimodal LLMs and AI agents.</p>
		</div>
		<div class="intro-button-navigation">
			<Button text="Blog" href="/blog" buttonStyle="gradient set-size"/>
			<Button text="Projects" href="/projects" buttonStyle="neutral-strong set-size"/>
			<Button text="About" href="/about" buttonStyle="neutral-strong set-size"/>
		</div>
	</section>
	<div class="content-sections-container">
		<section class="content-cards-container">
			<div class="first-row">
				<h2>Blog</h2>
				<Button text="All blog posts" href="/blog" buttonStyle="line gradient-underline icon-left" icon="rightarrow"/>
			</div>
			<div class="blog-content-cards">
				{
					blogPosts.slice(0, 3).map((post, index) => (
						<CardBlog post={post} compact backgroundColor={cardBlogBackgroundColors[index % cardBlogBackgroundColors.length]} transitionIcon/>
					))
				}
			</div>
		</section>
		<section class="content-cards-container">
			<div class="first-row">
				<h2>Projects</h2>
				<Button text="All projects" href="/projects" buttonStyle="line icon-left" icon="rightarrow"/>
			</div>
			<div class="projects-content-cards">
				<Card title="Unrot Me" href="https://github.com/shubhamgoel27/unrot-me">
					<p>Mindful movie and video recommendations powered by Streamlit.</p>
					<Icon name="lightbulb" label="lightbulb icon" size="1.5rem" slot="icon-row"/>
				</Card>
				<Card title="Gemini Image Labeler" href="https://github.com/shubhamgoel27/gemini-image-labeler">
					<p>Automated image annotation using Google Gemini multimodal LLMs.</p>
					<Icon name="magnifier" label="magnifier icon" size="1.5rem" slot="icon-row"/>
				</Card>
				<Card title="Satellite Image Downloader" href="https://github.com/shubhamgoel27/satellite-image-downloader">
					<p>Download, stitch, and georeference tiles from Google Static Maps API.</p>
					<Icon name="puzzle" label="puzzle icon" size="1.5rem" slot="icon-row"/>
				</Card>
			</div>
		</section>
		<section class="content-cards-container">
			<div class="first-row">
				<h2>Connect</h2>
			</div>
			<div class="some-content-row">
				<a href={socials.github.href} target="_blank" class="social-link">
					<Icon name="github" label="GitHub icon" size="2.5rem"/>
					<span>GitHub</span>
				</a>
				<a href={socials.linkedin.href} target="_blank" class="social-link">
					<Icon name="linkedin" label="LinkedIn icon" size="2.5rem"/>
					<span>LinkedIn</span>
				</a>
			</div>
		</section>
	</div>
</BaseLayout>

<style>
	.intro-section-container {
		display: flex;
		flex-direction: column;
		min-height: calc(100svh - var(--footer-height) - var(--navbar-height));
		justify-content: center;
	}
	.intro-container {
		margin-inline: auto;
		max-width: max-content;
		& .intro {
			display: flex;
			flex-direction: column-reverse;
			gap: var(--space-xs);
		}
	}
	.intro-button-navigation {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		justify-content: center;
		margin-block: var(--space-l);
		gap: var(--space-m) var(--space-l);
	}
	.content-sections-container {
		max-width: 64rem;
		width: 100%;
		margin-inline: auto;
	}
	.content-cards-container {
		margin-bottom: var(--space-2xl);
		.first-row {
			display: flex;
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
			gap: var(--space-m);
			margin-bottom: var(--space-m);
			h2 {
				margin-right: var(--space-s);
			}
		}
	}
	.blog-content-cards, .projects-content-cards {
		display: grid;
		gap: var(--space-l);
		grid-template-columns: 1fr;
	}
	.some-content-row {
		display: flex;
		gap: var(--space-l);
	}
	.social-link {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-xs);
		text-decoration: none;
		color: var(--color-neutral-300);
		transition: color var(--transition-normal);
		&:hover {
			color: var(--a-hover-color);
		}
	}
	@media only screen and (min-width: 48rem) {
		.intro-container .intro {
			flex-direction: row;
		}
		.intro-button-navigation {
			margin-block: var(--space-l);
			gap: var(--space-m) var(--space-l);
		}
		.blog-content-cards, .projects-content-cards {
			grid-template-columns: 1fr 1fr 1fr;
		}
	}
	@media only screen and (max-width: 35.999rem) {
		.content-cards-container .first-row {
			flex-direction: column;
			align-items: flex-start;
			gap: var(--space-s);
		}
	}
</style>
