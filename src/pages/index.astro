---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Squiggle from "../components/Squiggle.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PostCard from "../components/PostCard.astro";
import { featuredProjects } from "../data/projects";
import { socials, socialOrder } from "../data/socials";
import { minutesRead } from "../utils/reading";
import { Image } from "astro:assets";
import profilePic from "../assets/profile.png";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---
<Base>
  <section class="hero wrap">
    <button class="avatar" id="avatar-egg" aria-label="Shubham's photo. Click for a surprise." title="click me">
      <Image src={profilePic} alt="Shubham Goel" width={352} height={352} loading="eager" />
    </button>
    <h1 class="greeting">Hey, I'm Shubham.<Squiggle /></h1>
    <div class="lede narrow stack">
      <p>
        I'm a machine learning engineer with eight years across computer vision, multimodal
        learning, and recommender systems, most recently at Meta on Instagram Ads Ranking.
        Lately I'm most excited about <strong>multimodal LLMs, post-training, and
        <a href="/evals" class="evals-link">evals</a></strong>.
      </p>
      <p class="muted">
        I love building side projects, like
        <a href="https://github.com/shubhamgoel27/artifold" class="body-link">artifold</a> and
        <a href="https://github.com/shubhamgoel27/rl-arcade" class="body-link">rl-arcade</a>,
        and I have a serious obsession with <a href="/futbol" class="body-link">futbol</a>.
      </p>
    </div>
    <div class="hero-actions">
      <a href="/building" class="btn btn-primary">Projects</a>
      <a href="/about" class="btn btn-ghost">About</a>
    </div>
    <p class="now-line">
      <span class="pulse" aria-hidden="true"></span>
      Currently going deep on multimodal post-training and evals.
      <a href="/now" class="link-underline">what I'm up to now →</a>
    </p>
  </section>

  <section class="wrap block">
    <div class="block-head">
      <h2>Things I'm building</h2>
      <a href="/building" class="more link-underline">All projects →</a>
    </div>
    <div class="grid">
      {featuredProjects.map((p) => <ProjectCard project={p} />)}
    </div>
  </section>

  {posts.length > 0 && (
    <section class="wrap block narrow">
      <div class="block-head">
        <h2>Writing</h2>
        <a href="/blog" class="more link-underline">All posts →</a>
      </div>
      <div class="posts">
        {posts.map((post) => (
          <PostCard
            href={`/blog/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            minutesRead={minutesRead(post.body)}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  <section class="wrap block narrow">
    <h2>Say hi</h2>
    <p class="muted connect-lede">Always happy to talk multimodal models, recsys, football, or whatever you're building.</p>
    <ul class="connect">
      {socialOrder.map((key) => (
        <li>
          <a href={socials[key].href} class="connect-link" target={key === "email" ? undefined : "_blank"} rel="noopener">
            <span class="connect-label">{socials[key].label}</span>
            <span class="connect-handle">{socials[key].handle}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .hero { padding-top: var(--space-2xl); padding-bottom: var(--space-xl); }
  .avatar {
    display: block;
    width: 5.5rem;
    height: 5.5rem;
    padding: 0;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--paper-raised);
    box-shadow: var(--shadow-md);
    margin-bottom: var(--space-m);
    transform: rotate(-3deg);
    transition: transform var(--t-norm);
    cursor: pointer;
    background: none;
  }
  .avatar:hover { transform: rotate(3deg) scale(1.06); }
  .avatar.spin { animation: avatar-spin 0.55s var(--ease); }
  @keyframes avatar-spin { to { transform: rotate(357deg); } }
  .avatar :global(img) {
    /* zoom the circle crop in on the face */
    width: 200%;
    max-width: none;
    height: auto;
    margin-left: -50%;
  }
  .greeting { display: flex; flex-direction: column; align-items: flex-start; margin-top: var(--space-s); }
  .lede { margin-top: var(--space-l); font-size: var(--step-1); }
  .lede strong { color: var(--accent-ink); font-weight: 600; }
  .evals-link {
    color: var(--accent-ink);
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 100% 1.5px;
    transition: background-size var(--t-norm);
  }
  .evals-link:hover { background-size: 100% 3px; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-s); margin-top: var(--space-l); }
  .btn {
    display: inline-flex; align-items: center;
    padding: 0.7rem 1.3rem;
    border-radius: var(--radius-pill);
    font-weight: 540; font-size: 0.98rem;
    border: 1px solid transparent;
    transition: transform var(--t-fast), box-shadow var(--t-norm), background var(--t-fast), color var(--t-fast);
  }
  .btn-primary { background: var(--accent); color: #fff; box-shadow: var(--shadow-sm); }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .btn-ghost { color: var(--ink); border-color: var(--line-strong); background: var(--paper-raised); }
  .btn-ghost:hover { transform: translateY(-2px); border-color: var(--accent); color: var(--accent-ink); }

  .now-line {
    display: flex; align-items: center; flex-wrap: wrap; gap: 0.5em;
    margin-top: var(--space-l);
    font-size: 0.92rem; color: var(--ink-soft);
  }
  .now-line a { color: var(--accent-ink); }
  .pulse { width: 9px; height: 9px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 60%, transparent); animation: pulse 2.4s infinite; }
  @keyframes pulse { 70% { box-shadow: 0 0 0 7px transparent; } 100% { box-shadow: 0 0 0 0 transparent; } }
  @media (prefers-reduced-motion: reduce) { .pulse { animation: none; } }

  .block { padding-top: var(--space-xl); }
  .block-head { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-s); margin-bottom: var(--space-m); }
  .more { font-size: 0.92rem; color: var(--accent-ink); white-space: nowrap; }
  .grid { display: grid; grid-template-columns: 1fr; gap: var(--space-s); }
  @media (min-width: 46rem) { .grid { grid-template-columns: repeat(3, 1fr); } }

  .connect-lede { margin-top: var(--space-2xs); }
  .connect { display: grid; grid-template-columns: 1fr; gap: var(--space-xs); list-style: none; padding: 0; margin-top: var(--space-m); }
  @media (min-width: 34rem) { .connect { grid-template-columns: 1fr 1fr; } }
  .connect-link {
    display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-s);
    padding: 0.8rem 1rem;
    border: 1px solid var(--line); border-radius: var(--radius-m);
    background: var(--paper-raised); color: var(--ink);
    transition: border-color var(--t-fast), transform var(--t-fast), box-shadow var(--t-norm);
  }
  .connect-link:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: var(--shadow-sm); }
  .connect-label { font-weight: 560; }
  .connect-handle { font-family: var(--font-mono); font-size: 0.78rem; color: var(--ink-faint); }
</style>

<style is:global>
  .confetti {
    position: fixed;
    width: 9px;
    height: 9px;
    border-radius: 2px;
    pointer-events: none;
    z-index: 999;
  }
  .coyg-toast {
    position: fixed;
    transform: translate(-50%, -120%);
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--paper-raised);
    background: #EF0107;
    padding: 0.35rem 0.9rem;
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    pointer-events: none;
    z-index: 1000;
    animation: coyg-pop 1.6s var(--ease) forwards;
  }
  @keyframes coyg-pop {
    0% { opacity: 0; scale: 0.6; }
    15% { opacity: 1; scale: 1.05; }
    25% { scale: 1; }
    80% { opacity: 1; }
    100% { opacity: 0; translate: 0 -12px; }
  }
</style>

<script>
  const avatar = document.getElementById("avatar-egg");
  const ARSENAL = ["#EF0107", "#FFFDF8", "#9C824A", "#C1452A"];
  let clicks = 0;

  avatar?.addEventListener("click", () => {
    clicks++;
    avatar.classList.remove("spin");
    void avatar.offsetWidth;
    avatar.classList.add("spin");
    if (clicks % 5 === 0) celebrate();
  });

  function celebrate() {
    const r = avatar!.getBoundingClientRect();
    const cx = r.left + r.width / 2;
    const cy = r.top + r.height / 2;
    toast(cx, r.top);
    if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    for (let i = 0; i < 36; i++) {
      const p = document.createElement("span");
      p.className = "confetti";
      p.style.background = ARSENAL[i % ARSENAL.length];
      p.style.left = `${cx}px`;
      p.style.top = `${cy}px`;
      document.body.appendChild(p);
      const ang = Math.random() * Math.PI * 2;
      const v = 90 + Math.random() * 170;
      const dx = Math.cos(ang) * v;
      const dy = Math.sin(ang) * v - 140;
      p.animate(
        [
          { transform: "translate(0,0) rotate(0deg)", opacity: 1 },
          { transform: `translate(${dx}px, ${dy + 260}px) rotate(${Math.random() * 720 - 360}deg)`, opacity: 0 },
        ],
        { duration: 950 + Math.random() * 650, easing: "cubic-bezier(0.2,0.6,0.3,1)" }
      ).onfinish = () => p.remove();
    }
  }

  function toast(x: number, topY: number) {
    const t = document.createElement("div");
    t.className = "coyg-toast";
    t.textContent = "COYG! ⚽";
    t.style.left = `${x}px`;
    t.style.top = `${topY}px`;
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 1700);
  }
</script>
